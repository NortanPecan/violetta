# Violett a configuration
# Copy to .env and fill

# Preferred: local Ollama (no key needed)
# Make sure `ollama serve` is running and you have pulled a model, e.g.:
# ollama pull llama3.2
# ollama pull mistral   (good for Russian too)

# If you want to use Grok / xAI API instead:
# XAI_API_KEY=your_xai_key_here

# Default model when using Ollama
# Cloud model (current): gemma4:31b-cloud (free hosted)
# To switch back to local: gemma4:e4b (E4B) or gemma4:e2b (E2B)
OLLAMA_MODEL=gemma4:31b-cloud

# === Cloud model (default) ===
# gemma4:31b-cloud is free. Easy switch back by changing OLLAMA_MODEL.
# For paid cloud like kimi-*:cloud set OLLAMA_API_KEY and keep BASE_URL pointing to local ollama proxy.

# Temperature and tokens for cloud
OLLAMA_TEMPERATURE=0.6
OLLAMA_MAX_TOKENS=450

# Local fallback example:
# OLLAMA_MODEL=gemma4:e4b
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_TEMPERATURE=0.65
# OLLAMA_MAX_TOKENS=400

# For cloud models (gemma4:*:cloud free; kimi etc may need sub):
# OLLAMA_API_KEY=... (only if the cloud variant requires it)
# Calls use local Ollama (http://localhost:11434/v1) as proxy for :cloud models.

# Model when XAI_API_KEY is set (Grok models)
XAI_MODEL=grok-3

# Optional: database location (defaults to violetta_memory.db next to the app)
# SQLITE_DB_PATH=violetta_memory.db

# For future image generation of forms (not implemented in v1)
# IMAGE_GEN_ENABLED=false
